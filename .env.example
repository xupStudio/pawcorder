# Copy this file to .env and fill in. Generated by `install.sh` if absent.
# Do NOT commit .env to git.
#
# Per-camera config lives in config/cameras.yml (managed by the admin panel).
# This file holds only host-wide settings.

# ---------- Storage ----------
# Where Frigate writes recordings and snapshots. Can be a local path or
# a mountpoint backed by NAS (SMB/NFS).
STORAGE_PATH=/mnt/pawcorder

# ---------- Frigate ----------
# Password for go2rtc / restream auth. Generate a random one.
FRIGATE_RTSP_PASSWORD=changeme

# ---------- System ----------
TZ=Asia/Taipei

# ---------- Detection tuning ----------
# Applied to both cat and dog tracking on every camera. Lower values catch
# more pets but produce more false positives. 0.65 / 0.70 are reasonable
# defaults.
PET_MIN_SCORE=0.65
PET_THRESHOLD=0.70

# ---------- Admin panel ----------
# Set during install.sh. Used to log into the web admin panel.
ADMIN_PASSWORD=changeme
# Random secret for signing session cookies. Auto-generated on install.
ADMIN_SESSION_SECRET=changeme
