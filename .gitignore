# Secrets and local config
.env
.env.local

# Generated config (rendered from template). Frigate reads /config/config.yml.
config/config.yml

# Camera list — contains plaintext passwords, managed by admin panel
config/cameras.yml

# Other Frigate / admin runtime config (re-rendered or migrated on boot)
config/config.yaml
config/privacy.json
config/reliability.ndjson
config/go2rtc_homekit.yml
config/.exports
config/.jwt_secret
config/.timeline
config/.vacuum

# Master encryption key + metadata — managed by admin/master_key.py
master.key
master_key.meta.json

# Host-side scanner snapshots written by scripts/wifi-scan.sh +
# scripts/ble-scan.sh. Refreshed every 30s by launchd / systemd; the
# admin reads them via the bind-mounted /data volume.
.wifi_scan.json
.arp_scan.json
.ble_scan.json

# Host helpers virtualenv (bleak for BLE host scanner). Recreated by
# install.sh's _ensure_host_helpers_venv_macos.
.host-helpers-venv/

# Auto-generated docs (regenerated from sources at runtime).
INTEGRATIONS.md

# Frigate runtime data (if stored locally)
storage/
media/
*.db
*.db-shm
*.db-wal

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
coverage.xml
htmlcov/
admin/.venv/

# Claude Code local working files (auto-memory, skills, todos)
.claude/

# Usability harness runtime artifacts — see _testdir/usability/README.md.
# We commit the harness (scripts/, plans/, package.json) so personas can be
# re-run, but ignore node_modules + per-run screenshots + auto-generated
# *-trace.md so the repo doesn't grow on every run.
_testdir/usability/node_modules/
_testdir/usability/screenshots/
_testdir/usability/reports/*-trace.md
